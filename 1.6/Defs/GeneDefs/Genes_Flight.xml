        <drawSize>0.9</drawSize>
        <parentTagDef>Body</parentTagDef>
        <colorType>Skin</colorType>
        <drawData>
          <defaultData>
            <layer>-2</layer>
            <offset>(0, 0, -0.35)</offset>
          </defaultData>
          <dataNorth>
            <layer>90</layer>
            <offset>(0, 0, -0.35)</offset>
          </dataNorth>
          <dataEast>
            <layer>90</layer>
            <offset>(0, 0, -0.35)</offset>
          </dataEast>
          <dataWest>
            <layer>90</layer>
            <offset>(0, 0, -0.35)</offset>
